{
  "name": "raycast-qr-camera",
  "title": "QR Code Reader",
  "description": "Reads QR codes using the live camera feed and provides copy-able text.",
  "icon": "command-icon.png",
  "author": "GitHub Copilot",
  "owner": "githubcopilot",
  "license": "MIT",
  "commands": [
    {
      "name": "read-qr-code",
      "title": "Read QR Code from Camera",
      "description": "Use live camera feed to read a QR code",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.79.0",
    "react": "^18.2.0",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "20.8.10",
    "@types/react": "18.2.27",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
